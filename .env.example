PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<db_username>:<db_password>@codemaya-assignment.9vxavf7.mongodb.net/codemaya_assignment?retryWrites=true&w=majority&appName=codemaya-assignment
MONGO_MAX_RETRIES=0
MONGO_RETRY_DELAY_MS=5000
ENABLE_IN_MEMORY_MONGO_FALLBACK=false
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1d

# LLM configuration (Groq only)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
LLM_BASE_URL=https://api.groq.com/openai/v1

# For local dev/testing when no API key is available
ALLOW_MOCK_LLM=false

ASK_RATE_LIMIT_PER_MINUTE=10
