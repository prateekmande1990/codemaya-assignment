PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/codemaya_assignment
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1d

# LLM provider configuration (OpenAI-compatible)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# For local dev/testing when no API key is available
ALLOW_MOCK_LLM=false

ASK_RATE_LIMIT_PER_MINUTE=10
